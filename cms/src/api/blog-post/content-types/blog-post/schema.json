{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Technical blog article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "blocks"
    },
    "tags": {
      "type": "json"
    },
    "publishedAtCustom": {
      "type": "date"
    },
    "coverImageUrl": {
      "type": "string"
    },
    "readingTime": {
      "type": "integer"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "language": {
      "type": "enumeration",
      "default": "en",
      "enum": [
        "en",
        "pl"
      ]
    }
  }
}
