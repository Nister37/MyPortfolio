HOST=0.0.0.0
PORT=1337

APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# GitHub fine-grained PAT with Actions: read/write on Nister37/MyPortfolio.
# Triggers a GitHub Pages rebuild when a blog post or project is published.
GITHUB_REBUILD_TOKEN=

# SQLite is the default for local development.
# Switch to PostgreSQL for production.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
