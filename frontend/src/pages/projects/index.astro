---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/cms/projects";
import ProjectFilter from "../../components/projects/ProjectFilter.svelte";
import Section from "../../components/layout/Section.astro";
import { base } from "../../lib/url";

const projects = await getProjects();
---

<BaseLayout
  title="Projects | Paweł Ryfiak"
  description="A full list of projects I built or contributed to — backend systems, DevOps pipelines, AI tools, and more."
  path="/projects"
>
  <main id="main-content">
    <Section>
      <h1 class="text-4xl font-bold tracking-tight">Projects</h1>
      <p class="mt-3 max-w-2xl text-base-content/65">
        Real systems and tools, not toy examples. Each entry links to a detailed case study
        with problem context, stack rationale, and technical decisions.
      </p>

      <div class="mt-10">
        <!-- ProjectFilter is a Svelte island — only hydrated on this page -->
        <ProjectFilter client:load projects={projects} projectBase={`${base}projects/`} />
      </div>
    </Section>
  </main>
</BaseLayout>





