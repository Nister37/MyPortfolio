---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/cms/projects";
import type { Project } from "../../lib/cms/projects";
import Section from "../../components/layout/Section.astro";

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const lang = (Astro.currentLocale ?? "en") as "en" | "pl";

const labels = {
  en: {
    allProjects: "← All projects",
    technicalHighlights: "Technical highlights",
    problem: "Problem",
    myRole: "My role",
    architecture: "Architecture",
    hardestProblem: "Hardest technical problem",
    lessonsLearned: "What I learned",
    viewOnGitHub: "View on GitHub",
    liveDemo: "Live demo",
  },
  pl: {
    allProjects: "← Wszystkie projekty",
    technicalHighlights: "Najważniejsze aspekty techniczne",
    problem: "Problem",
    myRole: "Moja rola",
    architecture: "Architektura",
    hardestProblem: "Najtrudniejszy problem techniczny",
    lessonsLearned: "Wnioski",
    viewOnGitHub: "Zobacz na GitHub",
    liveDemo: "Demo na żywo",
  },
};
const l = labels[lang];

const allProjectsHref = lang === "pl" ? `${base}pl/projects` : `${base}projects`;

const proseSections = [
  { heading: l.problem, content: project.problem },
  { heading: l.myRole, content: project.myRole },
  { heading: l.architecture, content: project.architecture },
  { heading: l.hardestProblem, content: project.hardestProblem },
  { heading: l.lessonsLearned, content: project.lessonsLearned },
].filter((s) => s.content);
---

<BaseLayout
  title={`${project.title} | Pawel Ryfiak`}
  description={project.summary}
  lang={lang}
>
  <main id="main-content">
    <Section>
      <a class="link link-primary text-sm" href={allProjectsHref}>{l.allProjects}</a>

      <div class="mt-6 flex flex-wrap gap-2">
        {project.categories.map((cat) => (
          <span class="badge badge-primary">{cat}</span>
        ))}
      </div>

      <h1 class="mt-4 text-4xl font-bold tracking-tight">{project.title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-base-content/70">{project.summary}</p>

      <!-- Tech stack -->
      <div class="mt-5 flex flex-wrap gap-2">
        {project.stack.map((item) => (
          <span class="badge badge-outline">{item}</span>
        ))}
      </div>

      <!-- Technical highlights -->
      {
        project.highlights.length > 0 && (
          <div class="mt-10 rounded-xl border border-base-300 bg-base-200 p-6">
            <h2 class="text-lg font-semibold">{l.technicalHighlights}</h2>
            <ul class="mt-4 space-y-2">
              {project.highlights.map((point) => (
                <li class="flex items-start gap-3 text-base-content/75">
                  <span class="mt-0.5 text-primary" aria-hidden="true">▸</span>
                  {point}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Case study sections -->
      {
        proseSections.length > 0 && (
          <div class="mt-10 space-y-10 max-w-3xl">
            {proseSections.map(({ heading, content }) => (
              <div>
                <h2 class="text-xl font-semibold">{heading}</h2>
                <p class="mt-3 leading-relaxed text-base-content/75">{content}</p>
              </div>
            ))}
          </div>
        )
      }

      <!-- Links -->
      <div class="mt-12 flex flex-wrap gap-3">
        {
          project.githubUrl && (
            <a
              href={project.githubUrl}
              class="btn btn-outline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {l.viewOnGitHub}
            </a>
          )
        }
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              class="btn btn-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              {l.liveDemo}
            </a>
          )
        }
        <a href={allProjectsHref} class="btn btn-ghost">{l.allProjects}</a>
      </div>
    </Section>
  </main>
</BaseLayout>

