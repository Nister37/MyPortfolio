---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/cms/projects";
import type { Project } from "../../lib/cms/projects";
import Section from "../../components/layout/Section.astro";

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

// Prose sections rendered only when the field contains content
const proseSections = [
  { heading: "Problem", content: project.problem },
  { heading: "My role", content: project.myRole },
  { heading: "Architecture", content: project.architecture },
  { heading: "Hardest technical problem", content: project.hardestProblem },
  { heading: "What I learned", content: project.lessonsLearned },
].filter((s) => s.content);
---

<BaseLayout
  title={`${project.title} | Pawel Ryfiak`}
  description={project.summary}
>
  <main id="main-content">
    <Section>
      <a class="link link-primary text-sm" href="/projects">← All projects</a>

      <div class="mt-6 flex flex-wrap gap-2">
        {project.categories.map((cat) => (
          <span class="badge badge-primary">{cat}</span>
        ))}
      </div>

      <h1 class="mt-4 text-4xl font-bold tracking-tight">{project.title}</h1>
      <p class="mt-4 max-w-3xl text-lg text-base-content/70">{project.summary}</p>

      <!-- Tech stack -->
      <div class="mt-5 flex flex-wrap gap-2">
        {project.stack.map((item) => (
          <span class="badge badge-outline">{item}</span>
        ))}
      </div>

      <!-- Technical highlights -->
      {
        project.highlights.length > 0 && (
          <div class="mt-10 rounded-xl border border-base-300 bg-base-200 p-6">
            <h2 class="text-lg font-semibold">Technical highlights</h2>
            <ul class="mt-4 space-y-2">
              {project.highlights.map((point) => (
                <li class="flex items-start gap-3 text-base-content/75">
                  <span class="mt-0.5 text-primary" aria-hidden="true">▸</span>
                  {point}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Case study sections (problem, role, architecture etc.) -->
      {
        proseSections.length > 0 && (
          <div class="mt-10 space-y-10 max-w-3xl">
            {proseSections.map(({ heading, content }) => (
              <div>
                <h2 class="text-xl font-semibold">{heading}</h2>
                <p class="mt-3 leading-relaxed text-base-content/75">{content}</p>
              </div>
            ))}
          </div>
        )
      }

      <!-- Links -->
      <div class="mt-12 flex flex-wrap gap-3">
        {
          project.githubUrl && (
            <a
              href={project.githubUrl}
              class="btn btn-outline"
              target="_blank"
              rel="noopener noreferrer"
            >
              View on GitHub
            </a>
          )
        }
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              class="btn btn-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              Live demo
            </a>
          )
        }
        <a href="/projects" class="btn btn-ghost">← All projects</a>
      </div>
    </Section>
  </main>
</BaseLayout>
