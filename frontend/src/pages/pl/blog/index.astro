---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPostsByLanguage } from "../../../lib/cms/posts";
import BlogCard from "../../../components/blog/BlogCard.astro";
import Section from "../../../components/layout/Section.astro";

const posts = await getPostsByLanguage("pl");
---

<BaseLayout
  title="Blog | Paweł Ryfiak"
  description="Krótkie techniczne wpisy o Spring Boot, Dockerze, GitLab CI/CD i GitHub Actions. Nie tutoriale — rzeczy, których sam szukałem i których nie było dobrze udokumentowanych."
  lang="pl"
  path="/blog"
>
  <main id="main-content">
    <Section>
      <div data-reveal>
        <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
        <p class="mt-3 max-w-2xl text-base-content/65">
          Krótkie techniczne wpisy o backendzie, wzorcach wdrożeniowych, narzędziach AI
          oraz o rzeczach, których brakowało mi w dokumentacji, gdy ich potrzebowałem.
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} lang="pl" />)}
      </div>

      {
        posts.length === 0 && (
          <p class="mt-12 text-center text-base-content/50">
            Wpisy pojawią się wkrótce.
          </p>
        )
      }
    </Section>
  </main>
</BaseLayout>


