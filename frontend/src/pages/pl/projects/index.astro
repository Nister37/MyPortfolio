---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getProjects } from "../../../lib/cms/projects";
import ProjectFilter from "../../../components/projects/ProjectFilter.svelte";
import Section from "../../../components/layout/Section.astro";

const projects = await getProjects();
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<BaseLayout
  title="Projekty | Paweł Ryfiak"
  description="Pełna lista projektów — aplikacje backendowe, procesy CI/CD, narzędzia automatyzujące i więcej."
  lang="pl"
  path="/projects"
>
  <main id="main-content">
    <Section>
      <h1 class="text-4xl font-bold tracking-tight">Projekty</h1>
      <p class="mt-3 max-w-2xl text-base-content/65">
        Wybrane projekty i narzędzia. Każdy wpis zawiera szczegółowe studium przypadku
        z kontekstem problemu, uzasadnieniem stosu technologicznego i podjętymi decyzjami
        technicznymi.
      </p>

      <div class="mt-10">
        <ProjectFilter client:load projects={projects} lang="pl" projectBase={`${base}pl/projects/`} />
      </div>
    </Section>
  </main>
</BaseLayout>





