---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPostsByLanguage } from "../../lib/cms/posts";
import BlogCard from "../../components/blog/BlogCard.astro";
import Section from "../../components/layout/Section.astro";

const posts = await getPostsByLanguage("en");
---

<BaseLayout
  title="Blog | Paweł Ryfiak"
  description="Short technical posts on Spring Boot, Docker, GitLab CI/CD, GitHub Actions, and lessons from real projects. Honest writing — not tutorials, just things that took time to figure out."
>
  <main id="main-content">
    <Section>
      <div data-reveal>
        <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
        <p class="mt-3 max-w-2xl text-base-content/65">
          Short technical posts on backend engineering, deployment patterns, AI tooling, and
          things I wish I had found documented when I needed them.
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} lang="en" />)}
      </div>

      {
        posts.length === 0 && (
          <p class="mt-12 text-center text-base-content/50">
            Posts are coming soon.
          </p>
        )
      }
    </Section>
  </main>
</BaseLayout>





