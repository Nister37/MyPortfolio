---
interface Props {
  // Caller can override size; default keeps desktop header compact.
  class?: string;
}
const { class: className = "btn btn-ghost btn-sm" } = Astro.props;
---

<button
  class:list={["theme-toggle", className]}
  aria-label="Toggle colour theme"
  title="Toggle light / dark"
>
  <!-- Sun icon — shown in dark mode -->
  <svg
    class="icon-sun h-4 w-4"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    />
  </svg>
  <!-- Moon icon — shown in light mode -->
  <svg
    class="icon-moon h-4 w-4 hidden"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"
    />
  </svg>
</button>

<script>
  const DARK = "portfolio-dark";
  const LIGHT = "portfolio-light";
  const STORAGE_KEY = "portfolio-theme";

  // Updates every toggle button on the page (desktop + mobile instances share
  // the same document theme, so both icons must stay in sync).
  function applyTheme(theme: string) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem(STORAGE_KEY, theme);
    document.querySelectorAll<HTMLElement>(".theme-toggle").forEach((btn) => {
      btn.querySelector<SVGElement>(".icon-sun")?.classList.toggle("hidden", theme !== DARK);
      btn.querySelector<SVGElement>(".icon-moon")?.classList.toggle("hidden", theme === DARK);
    });
  }

  // Restore persisted theme before first paint.
  const saved = localStorage.getItem(STORAGE_KEY);
  applyTheme(saved === LIGHT ? LIGHT : DARK);

  // Wire every toggle button — querySelectorAll handles both instances.
  document.querySelectorAll<HTMLButtonElement>(".theme-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const current = document.documentElement.getAttribute("data-theme");
      applyTheme(current === DARK ? LIGHT : DARK);
    });
  });
</script>
