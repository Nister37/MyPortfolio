---
// Hero is the first thing a visitor sees — text and CTAs only, no decorative noise.
---

<section class="py-20 md:py-32">
  <div class="mx-auto max-w-[1120px] px-4">
    <div class="max-w-3xl" data-reveal>
      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-primary">
        Available for opportunities
      </p>

      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Pawel Ryfiak
      </h1>

      <p class="mt-4 text-xl font-medium text-base-content/80 md:text-2xl">
        Junior Software Engineer focused on backend, automation, and practical DevOps.
      </p>

      <p class="mt-6 max-w-2xl text-base leading-relaxed text-base-content/65">
        I build Spring Boot systems, deployment pipelines, AI-assisted data extraction tools, and
        infrastructure scripts. Currently learning Astro, Svelte, Strapi, and modern frontend
        workflows by building this portfolio.
      </p>

      <p class="mt-3 text-sm text-base-content/50">
        Open to: IT internship, junior backend, automation, DevOps-oriented roles
        &bull; Antwerp / remote / EU
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/projects" class="btn btn-primary">
          View Projects
        </a>
        <a href="/blog" class="btn btn-outline">
          Read Blog
        </a>
        <a
          href="/cv.pdf"
          class="btn btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Download CV
        </a>
        <a
          href="https://github.com/pawelryfiak"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/pawelryfiak2004"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn profile"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>



