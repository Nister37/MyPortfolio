---
interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const projectsHref = lang === "pl" ? `${base}pl/projects` : `${base}projects`;
const blogHref = lang === "pl" ? `${base}pl/blog` : `${base}blog`;

const copy = {
  en: {
    available: "Available for opportunities",
    subtitle: "Junior Software Engineer focused on backend, automation, and practical DevOps.",
    body: "I build Spring Boot systems, deployment pipelines, AI-assisted data extraction tools, and infrastructure scripts. Currently learning Astro, Svelte, Strapi, and modern frontend workflows by building this portfolio.",
    openTo: "Open to: IT internship, junior backend, automation, DevOps-oriented roles · Antwerp / remote / EU",
    viewProjects: "View Projects",
    readBlog: "Read Blog",
    downloadCv: "Download CV",
  },
  pl: {
    available: "Otwarty na oferty",
    subtitle: "Junior Software Engineer — backend, automatyzacja i praktyczny DevOps.",
    body: "Buduję systemy Spring Boot, pipeline'y wdrożeniowe, narzędzia do ekstrakcji danych z AI i skrypty infrastrukturalne. Aktualnie uczę się Astro, Svelte, Strapi i nowoczesnego frontendu, budując to portfolio.",
    openTo: "Szukam: stażu IT, junior backend, automatyzacja, role DevOps · Antwerpia / zdalnie / UE",
    viewProjects: "Zobacz projekty",
    readBlog: "Czytaj bloga",
    downloadCv: "Pobierz CV",
  },
};
const c = copy[lang];
---

<section class="py-20 md:py-32">
  <div class="mx-auto max-w-[1120px] px-4">
    <div class="max-w-3xl" data-reveal>
      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-primary">
        {c.available}
      </p>

      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Pawel Ryfiak
      </h1>

      <p class="mt-4 text-xl font-medium text-base-content/80 md:text-2xl">
        {c.subtitle}
      </p>

      <p class="mt-6 max-w-2xl text-base leading-relaxed text-base-content/65">
        {c.body}
      </p>

      <p class="mt-3 text-sm text-base-content/50">
        {c.openTo}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={projectsHref} class="btn btn-primary">
          {c.viewProjects}
        </a>
        <a href={blogHref} class="btn btn-outline">
          {c.readBlog}
        </a>
        <a
          href={`${base}cv.pdf`}
          class="btn btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          {c.downloadCv}
        </a>
        <a
          href="https://github.com/Nister37"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/pawelryfiak2004"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn profile"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
