---
import { getPosts } from "../../lib/cms/posts";
import BlogCard from "../blog/BlogCard.astro";
import Section from "../layout/Section.astro";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

// Filter by post.language if present; posts without a language flag are treated as English.
const allPosts = await getPosts();
const localePosts = allPosts.filter((p) => (p.language ?? "en") === lang);
const previewPosts = localePosts.slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const blogHref = lang === "pl" ? `${base}pl/blog` : `${base}blog`;
---
<Section id="blog">
  <div class="mb-10 flex items-end justify-between">
    <div>
      <h2 class="text-3xl font-bold tracking-tight">
        {lang === "pl" ? "Ostatnie wpisy" : "Recent Posts"}
      </h2>
      <p class="mt-2 text-base-content/60">
        {lang === "pl"
          ? "Techniczne notatki o rzeczach, które zbudowałem, debugowałem lub zrozumiałem po ciężkiej drodze."
          : "Technical writing on things I built, debugged, or learned the hard way."}
      </p>
    </div>
    <a href={blogHref} class="btn btn-outline btn-sm hidden md:inline-flex">
      {lang === "pl" ? "Wszystkie wpisy ->" : "All posts ->"}
    </a>
  </div>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {previewPosts.map((post) => <BlogCard post={post} lang={lang} />)}
  </div>
  <div class="mt-8 md:hidden">
    <a href={blogHref} class="btn btn-outline w-full">
      {lang === "pl" ? "Wszystkie wpisy ->" : "All posts ->"}
    </a>
  </div>
</Section>

