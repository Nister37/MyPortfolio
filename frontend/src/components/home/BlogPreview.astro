---
import { getPosts } from "../../lib/cms/posts";
import BlogCard from "../blog/BlogCard.astro";
import Section from "../layout/Section.astro";
const allPosts = await getPosts();
const previewPosts = allPosts.slice(0, 3);
const base = import.meta.env.BASE_URL;
---
<Section id="blog">
  <div class="mb-10 flex items-end justify-between">
    <div>
      <h2 class="text-3xl font-bold tracking-tight">Recent Posts</h2>
      <p class="mt-2 text-base-content/60">
        Technical writing on things I built, debugged, or learned the hard way.
      </p>
    </div>
    <a href={`${base}blog`} class="btn btn-outline btn-sm hidden md:inline-flex">
      All posts ->
    </a>
  </div>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {previewPosts.map((post) => <BlogCard post={post} />)}
  </div>
  <div class="mt-8 md:hidden">
    <a href={`${base}blog`} class="btn btn-outline w-full">All posts -></a>
  </div>
</Section>