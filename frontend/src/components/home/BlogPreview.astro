---
import { getPosts } from "../../lib/cms/posts";
import BlogCard from "../blog/BlogCard.astro";
import Section from "../layout/Section.astro";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

// Filter by post.language if present; posts without a language flag are treated as English.
const allPosts = await getPosts();
const localePosts = allPosts.filter((p) => (p.language ?? "en") === lang);
// Render up to three (matches the widest row at `lg`). Cards beyond row
// capacity at smaller breakpoints are hidden via Tailwind utilities so the
// section is always exactly one row tall.
const previewPosts = localePosts.slice(0, 3);

const visibilityClass = (index: number) => {
  if (index === 0) return "";
  if (index === 1) return "hidden md:block";
  return "hidden lg:block";
};
---
<Section id="blog">
  <div class="mb-10" data-reveal>
    <h2 class="text-3xl font-bold tracking-tight">
      {lang === "pl" ? "Ostatnie wpisy" : "Recent Posts"}
    </h2>
    <p class="mt-2 text-base-content/60">
      {lang === "pl"
        ? "Techniczne notatki o projektach, problemach i decyzjach, które pojawiły się podczas budowania aplikacji, automatyzacji i infrastruktury."
        : "Technical writing on things I built, debugged, or learned the hard way."}
    </p>
  </div>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {previewPosts.map((post, index) => (
      <div class={visibilityClass(index)}>
        <BlogCard post={post} lang={lang} />
      </div>
    ))}
  </div>
</Section>




