---
import Section from "../layout/Section.astro";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

type TimelineEntry = {
  title: string;
  organization: string;
  period: string;
  description?: string;
};

// Education column — newest first.
const education: TimelineEntry[] = [
  {
    title: lang === "pl" ? "Informatyka Stosowana" : "Applied Computer Science",
    organization:
      lang === "pl"
        ? "Karel de Grote Hogeschool, Antwerpia"
        : "Karel de Grote Hogeschool, Antwerp",
    period: lang === "pl" ? "2024 — obecnie" : "2024 — present",
    description:
      lang === "pl"
        ? "Studia anglojęzyczne skoncentrowane na tworzeniu aplikacji, bazach danych, analizie systemów, testowaniu, pracy zespołowej i praktycznych projektach programistycznych."
        : "Backend development, databases, networking, and project management. Focus on practical engineering over theory.",
  },
  {
    title: lang === "pl" ? "Technik programista" : "Programming Technician",
    organization:
      lang === "pl"
        ? "Zespół Szkół Politechnicznych w Głogowie"
        : "Polytechnic School Complex in Głogów, Poland",
    period: "2019 — 2024",
    description:
      lang === "pl"
        ? "Pięcioletnie technikum o profilu programistycznym. Podstawy programowania, baz danych, sieci komputerowych oraz egzaminy zawodowe INF.03 i INF.04."
        : "Five-year technical secondary school specialising in programming. Foundations of programming, databases, computer networks, and professional certifications INF.03 and INF.04.",
  },
];

// Projects & work column — newest first.
const experience: (TimelineEntry & { type: "Project" | "Work" })[] = [
  {
    title: "Integration 4 CI/CD on Google Cloud",
    organization: lang === "pl" ? "Projekt uczelniany" : "Academic project",
    period: "2026",
    type: "Project",
    description:
      lang === "pl"
        ? "Projekt wdrożeniowy obejmujący GitLab CI, Docker, Google Compute Engine, Nginx, HTTPS oraz strategię blue-green deployment. Skupiał się na automatyzacji deploymentu i ograniczeniu przestojów aplikacji."
        : "Full CI/CD pipeline on GCE with GitLab CI, Docker, and Nginx. Blue-green deployment strategy with automated health checks.",
  },
  {
    title: "ServicePulse Link Monitor",
    organization: lang === "pl" ? "Projekt własny" : "Personal project",
    period: "2026",
    type: "Project",
    description:
      lang === "pl"
        ? "Aplikacja Spring Boot do monitorowania dostępności endpointów HTTP. Projekt łączy backend, PostgreSQL, Docker Compose, reverse proxy Caddy oraz podstawy deploymentu na serwerze."
        : "HTTP endpoint monitoring service with configurable schedules, failure alerting, and persistent history — built with Spring Boot and Docker.",
  },
  {
    title: "Roometrix IoT Air Quality System",
    organization: lang === "pl" ? "Projekt uczelniany" : "Academic project",
    period: "2025",
    type: "Project",
    description:
      lang === "pl"
        ? "Projekt systemu IoT do monitorowania jakości powietrza w pomieszczeniach. Obejmował zbieranie danych z czujników, backend API, zapis danych oraz proste alerty progowe."
        : "MQTT-based sensor data ingestion for air quality monitoring with REST API and threshold alerting.",
  },
  {
    title: lang === "pl" ? "Staż programistyczny" : "Programming internship",
    organization: "NSI",
    period: "2022",
    type: "Work",
    description:
      lang === "pl"
        ? "Krótki staż zawodowy w trakcie nauki w technikum — pierwsze zetknięcie z pracą w środowisku IT."
        : "Short professional internship during secondary school — first exposure to working in an IT environment.",
  },
];

const heading = lang === "pl" ? "Doświadczenie i edukacja" : "Experience & Education";
const subheading =
  lang === "pl"
    ? "Równolegle: edukacja po lewej, projekty i doświadczenie zawodowe po prawej."
    : "Side by side: education on the left, projects and work experience on the right.";
const educationLabel = lang === "pl" ? "Edukacja" : "Education";
const experienceLabel = lang === "pl" ? "Projekty i doświadczenie" : "Projects & Experience";

const workTypeLabel = lang === "pl" ? "Praca" : "Work";
const projectTypeLabel = lang === "pl" ? "Projekt" : "Project";
---

<Section id="experience">
  <h2 class="text-3xl font-bold tracking-tight">{heading}</h2>
  <p class="mt-2 text-base-content/60">{subheading}</p>

  <div class="mt-10 grid gap-10 md:grid-cols-2">
    <!-- Education column -->
    <div>
      <h3 class="mb-6 text-sm font-semibold uppercase tracking-wider text-primary">
        {educationLabel}
      </h3>
      <ul class="space-y-5">
        {
          education.map((entry) => (
            <li class="relative border-l-2 border-primary/30 pl-5">
              <span class="absolute -left-[7px] top-1.5 block h-3 w-3 rounded-full border-2 border-primary bg-base-100" />
              <p class="text-xs text-base-content/50">{entry.period}</p>
              <h4 class="mt-1 font-semibold">{entry.title}</h4>
              <p class="text-sm text-base-content/60">{entry.organization}</p>
              {entry.description && (
                <p class="mt-2 text-sm text-base-content/70">{entry.description}</p>
              )}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Experience column -->
    <div>
      <h3 class="mb-6 text-sm font-semibold uppercase tracking-wider text-primary">
        {experienceLabel}
      </h3>
      <ul class="space-y-5">
        {
          experience.map((entry) => (
            <li class="relative border-l-2 border-primary/30 pl-5">
              <span class="absolute -left-[7px] top-1.5 block h-3 w-3 rounded-full border-2 border-primary bg-base-100" />
              <div class="mb-1 flex flex-wrap items-center gap-2">
                <span class="text-xs text-base-content/50">{entry.period}</span>
                <span
                  class:list={[
                    "badge badge-sm",
                    entry.type === "Work" ? "badge-secondary" : "badge-primary",
                  ]}
                >
                  {entry.type === "Work" ? workTypeLabel : projectTypeLabel}
                </span>
              </div>
              <h4 class="font-semibold">{entry.title}</h4>
              <p class="text-sm text-base-content/60">{entry.organization}</p>
              {entry.description && (
                <p class="mt-2 text-sm text-base-content/70">{entry.description}</p>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Section>

