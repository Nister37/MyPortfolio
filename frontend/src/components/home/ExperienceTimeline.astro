---
import Section from "../layout/Section.astro";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

type TimelineEntry = {
  title: string;
  organization: string;
  period: string;
  type: "Education" | "Project" | "Work" | "Hackathon";
  description: string;
};

// Static timeline — not CMS-sourced for the MVP.
const timeline: TimelineEntry[] = [
  {
    title: lang === "pl" ? "Informatyka Stosowana" : "Applied Computer Science",
    organization: lang === "pl" ? "Karel de Grote Hogeschool, Antwerpia" : "Karel de Grote Hogeschool, Antwerp",
    period: lang === "pl" ? "2024 — obecnie" : "2024 — present",
    type: "Education",
    description:
      lang === "pl"
        ? "Studia anglojęzyczne skoncentrowane na tworzeniu aplikacji, bazach danych, analizie systemów, testowaniu, pracy zespołowej i praktycznych projektach programistycznych."
        : "Backend development, databases, networking, and project management. Focus on practical engineering over theory.",
  },
  {
    title: "Integration 4 CI/CD on Google Cloud",
    organization: lang === "pl" ? "Projekt uczelniany" : "Academic project",
    period: "2026",
    type: "Project",
    description:
      lang === "pl"
        ? "Projekt wdrożeniowy obejmujący GitLab CI, Docker, Google Compute Engine, Nginx, HTTPS oraz strategię blue-green deployment. Skupiał się na automatyzacji deploymentu i ograniczeniu przestojów aplikacji."
        : "Full CI/CD pipeline on GCE with GitLab CI, Docker, and Nginx. Blue-green deployment strategy with automated health checks.",
  },
  {
    title: "ServicePulse Link Monitor",
    organization: lang === "pl" ? "Projekt własny" : "Personal project",
    period: "2026",
    type: "Project",
    description:
      lang === "pl"
        ? "Aplikacja Spring Boot do monitorowania dostępności endpointów HTTP. Projekt łączy backend, PostgreSQL, Docker Compose, reverse proxy Caddy oraz podstawy deploymentu na serwerze."
        : "HTTP endpoint monitoring service with configurable schedules, failure alerting, and persistent history — built with Spring Boot and Docker.",
  },
  {
    title: "Roometrix IoT Air Quality System",
    organization: lang === "pl" ? "Projekt uczelniany" : "Academic project",
    period: "2025",
    type: "Project",
    description:
      lang === "pl"
        ? "Projekt systemu IoT do monitorowania jakości powietrza w pomieszczeniach. Obejmował zbieranie danych z czujników, backend API, zapis danych oraz proste alerty progowe."
        : "MQTT-based sensor data ingestion for air quality monitoring with REST API and threshold alerting.",
  },
];

const typeBadge: Record<string, string> = {
  Education: "badge-accent",
  Project: "badge-primary",
  Work: "badge-secondary",
  Hackathon: "badge-ghost",
};

const typeLabel: Record<string, Record<string, string>> = {
  en: { Education: "Education", Project: "Project", Work: "Work", Hackathon: "Hackathon" },
  pl: { Education: "Edukacja", Project: "Projekt", Work: "Praca", Hackathon: "Hackathon" },
};
---

<Section id="experience">
  <h2 class="text-3xl font-bold tracking-tight">
    {lang === "pl" ? "Doświadczenie i edukacja" : "Experience & Education"}
  </h2>
  <p class="mt-2 text-base-content/60">
    {lang === "pl"
      ? "Kluczowe projekty i etapy, od najnowszych."
      : "Key projects and milestones, most recent first."}
  </p>

  <ul class="timeline timeline-vertical mt-10">
    {
      timeline.map((entry, index) => (
        <li>
          {index !== 0 && <hr class="bg-base-300" />}
          <div class="timeline-start text-sm text-base-content/50 md:text-right">
            {entry.period}
          </div>
          <div class="timeline-middle">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="h-5 w-5 text-primary"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                clip-rule="evenodd"
              />
            </svg>
          </div>
          <div class="timeline-end timeline-box mb-6 bg-base-200">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class:list={["badge badge-sm", typeBadge[entry.type]]}>
                {typeLabel[lang][entry.type]}
              </span>
            </div>
            <h3 class="font-semibold">{entry.title}</h3>
            <p class="text-sm text-base-content/60">{entry.organization}</p>
            <p class="mt-2 text-sm text-base-content/70">{entry.description}</p>
          </div>
          {index !== timeline.length - 1 && <hr class="bg-base-300" />}
        </li>
      ))
    }
  </ul>
</Section>

