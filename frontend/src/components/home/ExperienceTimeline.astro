---
import Section from "../layout/Section.astro";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const blogBase = lang === "pl" ? `${base}pl/blog/` : `${base}blog/`;

type EntryType = "Education" | "Project" | "Work";

type TimelineEntry = {
  title: string;
  organization: string;
  period: string;
  type: EntryType;
  description?: string;
  /** When set, the entire entry becomes a link to /blog/{blogSlug}. */
  blogSlug?: string;
};

// One merged timeline, newest first. Add `blogSlug` to any entry to make it
// clickable — the slug must match a published Blog Post entry in Strapi.
const entries: TimelineEntry[] = [
  {
    title: "Integration 4 CI/CD on Google Cloud",
    organization: lang === "pl" ? "Projekt uczelniany" : "Academic project",
    period: "2026",
    type: "Project",
    description:
      lang === "pl"
        ? "Projekt wdrożeniowy obejmujący GitLab CI, Docker, Google Compute Engine, Nginx, HTTPS oraz strategię blue-green deployment. Skupiał się na automatyzacji deploymentu i ograniczeniu przestojów aplikacji."
        : "Full CI/CD pipeline on GCE with GitLab CI, Docker, and Nginx. Blue-green deployment strategy with automated health checks.",
  },
  {
    title: "ServicePulse Link Monitor",
    organization: lang === "pl" ? "Projekt własny" : "Personal project",
    period: "2026",
    type: "Project",
    description:
      lang === "pl"
        ? "Aplikacja Spring Boot do monitorowania dostępności endpointów HTTP. Projekt łączy backend, PostgreSQL, Docker Compose, reverse proxy Caddy oraz podstawy deploymentu na serwerze."
        : "HTTP endpoint monitoring service with configurable schedules, failure alerting, and persistent history — built with Spring Boot and Docker.",
  },
  {
    title: "Roometrix IoT Air Quality System",
    organization: lang === "pl" ? "Projekt uczelniany" : "Academic project",
    period: "2025",
    type: "Project",
    description:
      lang === "pl"
        ? "Projekt systemu IoT do monitorowania jakości powietrza w pomieszczeniach. Obejmował zbieranie danych z czujników, backend API, zapis danych oraz proste alerty progowe."
        : "MQTT-based sensor data ingestion for air quality monitoring with REST API and threshold alerting.",
  },
  {
    title: lang === "pl" ? "Informatyka Stosowana" : "Applied Computer Science",
    organization:
      lang === "pl"
        ? "Karel de Grote Hogeschool, Antwerpia"
        : "Karel de Grote Hogeschool, Antwerp",
    period: lang === "pl" ? "2024 — obecnie" : "2024 — present",
    type: "Education",
    description:
      lang === "pl"
        ? "Studia anglojęzyczne skoncentrowane na tworzeniu aplikacji, bazach danych, analizie systemów, testowaniu, pracy zespołowej i praktycznych projektach programistycznych."
        : "Backend development, databases, networking, and project management. Focus on practical engineering over theory.",
  },
  {
    title: lang === "pl" ? "Staż programistyczny" : "Programming internship",
    organization: "NSI",
    period: "2022",
    type: "Work",
    description:
      lang === "pl"
        ? "Krótki staż zawodowy w trakcie nauki w technikum — pierwsze zetknięcie z pracą w środowisku IT."
        : "Short professional internship during secondary school — first exposure to working in an IT environment.",
  },
  {
    title: lang === "pl" ? "Technik programista" : "Programming Technician",
    organization:
      lang === "pl"
        ? "Zespół Szkół Politechnicznych w Głogowie"
        : "Polytechnic School Complex in Głogów, Poland",
    period: "2019 — 2024",
    type: "Education",
    description:
      lang === "pl"
        ? "Pięcioletnie technikum o profilu programistycznym. Podstawy programowania, baz danych, sieci komputerowych oraz egzaminy zawodowe INF.03 i INF.04."
        : "Five-year technical secondary school specialising in programming. Foundations of programming, databases, computer networks, and professional certifications INF.03 and INF.04.",
  },
];

const heading = lang === "pl" ? "Doświadczenie i edukacja" : "Experience & Education";
const subheading =
  lang === "pl"
    ? "Najnowsze na górze. Wpisy oznaczone linkiem prowadzą do powiązanego artykułu na blogu."
    : "Most recent first. Items marked as links open the related blog post.";

const typeBadgeClass: Record<EntryType, string> = {
  Education: "badge-accent",
  Project: "badge-primary",
  Work: "badge-secondary",
};

// Two lifelines: education on the left, work + projects on the right.
const educationEntries = entries.filter((entry) => entry.type === "Education");
const experienceEntries = entries.filter((entry) => entry.type !== "Education");

const educationHeading = lang === "pl" ? "Edukacja" : "Education";
const experienceHeading = lang === "pl" ? "Doświadczenie" : "Experience";

const columns = [
  { heading: educationHeading, entries: educationEntries },
  { heading: experienceHeading, entries: experienceEntries },
];
---

<Section id="experience">
  <h2 class="text-3xl font-bold tracking-tight">{heading}</h2>
  <p class="mt-2 text-base-content/60">{subheading}</p>

  <!-- Stacked on mobile (with the per-column subheading above each list);
       side-by-side on desktop, each column its own continuous lifeline. -->
  <div class="mt-10 grid gap-10 md:grid-cols-2 md:gap-8">
    {
      columns.map((column) => (
        <div>
          <h3 class="mb-5 text-sm font-semibold uppercase tracking-wider text-base-content/60">
            {column.heading}
          </h3>
          <ol class="timeline-list space-y-4 border-l-2 border-base-300 pl-8">
            {column.entries.map((entry) => {
              const Tag = entry.blogSlug ? "a" : "div";
              const href = entry.blogSlug ? `${blogBase}${entry.blogSlug}` : undefined;
              return (
                <li class="relative">
                  <span
                    class="timeline-dot absolute -left-[37px] top-5 block h-3.5 w-3.5 rounded-full border-2 border-primary bg-base-100 transition-all"
                    aria-hidden="true"
                  />
                  <Tag
                    {href}
                    class:list={[
                      "timeline-card block rounded-lg border border-base-300 bg-base-200/40 p-5 transition-all",
                      entry.blogSlug && "timeline-card--linked cursor-pointer",
                    ]}
                  >
                    <div class="mb-1 flex flex-wrap items-center gap-2">
                      <span class="text-xs text-base-content/50">{entry.period}</span>
                      <span class:list={["badge badge-sm", typeBadgeClass[entry.type]]}>
                        {entry.type === "Education"
                          ? lang === "pl" ? "Edukacja" : "Education"
                          : entry.type === "Project"
                            ? lang === "pl" ? "Projekt" : "Project"
                            : lang === "pl" ? "Praca" : "Work"}
                      </span>
                      {entry.blogSlug && (
                        <span class="ml-auto text-xs text-primary/80">
                          {lang === "pl" ? "Przeczytaj artykuł →" : "Read article →"}
                        </span>
                      )}
                    </div>
                    <h4 class="font-semibold">{entry.title}</h4>
                    <p class="text-sm text-base-content/60">{entry.organization}</p>
                    {entry.description && (
                      <p class="mt-2 text-sm text-base-content/70">{entry.description}</p>
                    )}
                  </Tag>
                </li>
              );
            })}
          </ol>
        </div>
      ))
    }
  </div>
</Section>

<style>
  /* Hover state — highlight border, lift, and fill the dot in primary blue. */
  .timeline-list :global(li:hover .timeline-dot) {
    background-color: var(--color-primary, #6366f1);
    border-color: var(--color-primary, #6366f1);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--color-primary, #6366f1) 22%, transparent);
  }

  .timeline-list :global(.timeline-card:hover) {
    border-color: color-mix(in srgb, var(--color-primary, #6366f1) 55%, transparent);
    background-color: color-mix(in srgb, var(--color-primary, #6366f1) 7%, transparent);
  }

  /* Linked cards get an extra lift to signal interactivity. */
  .timeline-list :global(.timeline-card--linked:hover) {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -12px color-mix(in srgb, var(--color-primary, #6366f1) 65%, transparent);
  }
</style>


