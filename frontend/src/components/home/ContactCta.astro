---
// ContactCta no longer imports Section — full-bleed bg handled by wrapper div instead.
const base = import.meta.env.BASE_URL;
---

<div class="bg-base-200">
  <section id="contact" class="py-16 md:py-24">
    <div class="mx-auto max-w-[1120px] px-4" data-reveal>
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight">Get in touch</h2>
        <p class="mt-4 text-base-content/65">
          I am open to IT internships, junior backend positions, automation roles, and
          DevOps-oriented opportunities. Based in Antwerp — available for remote and EU roles.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="mailto:pawel.ryfiak@gmail.com" class="btn btn-primary">
            Send an email
          </a>
          <a
            href="https://linkedin.com/in/pawelryfiak"
            class="btn btn-outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
          <a
            href="https://github.com/pawelryfiak"
            class="btn btn-outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>
          <a href={`${base}cv.pdf`} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
            Download CV
          </a>
        </div>

        <p class="mt-6 text-sm text-base-content/45">
          CV available on request if the PDF link is not yet live.
        </p>
      </div>
    </div>
  </section>
</div>

