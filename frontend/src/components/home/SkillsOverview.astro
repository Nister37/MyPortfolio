---
import Section from "../layout/Section.astro";
import { skillCategories } from "../../data/skills";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

const levelBadge: Record<string, string> = {
  Strong: "badge-primary",
  Good: "badge-secondary",
  Learning: "badge-ghost",
};

// Translated badge labels — keeps the visual weight tied to proficiency without fake bars.
const levelLabel: Record<string, Record<string, string>> = {
  en: { Strong: "Strong", Good: "Good", Learning: "Learning" },
  pl: { Strong: "Mocna", Good: "Dobra", Learning: "W nauce" },
};

const categoryLabel: Record<string, Record<string, string>> = {
  en: { Backend: "Backend", DevOps: "DevOps", "AI & Automation": "AI & Automation", Frontend: "Frontend", Database: "Database" },
  pl: { Backend: "Backend", DevOps: "DevOps", "AI & Automation": "AI i automatyzacja", Frontend: "Frontend", Database: "Bazy danych" },
};
---

<Section id="skills">
  <h2 class="text-3xl font-bold tracking-tight">
    {lang === "pl" ? "Umiejętności techniczne" : "Skills"}
  </h2>
  <p class="mt-2 text-base-content/60">
    {lang === "pl"
      ? "Technologie pogrupowane według obszaru."
      : "Grouped by domain. No fake percentages — labels show real relative confidence."}
  </p>

  <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      skillCategories.map(({ category, skills }) => (
        <div class="rounded-xl border border-base-300 bg-base-200 p-5">
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-primary">
            {categoryLabel[lang][category] ?? category}
          </h3>
          <ul class="space-y-3">
            {skills.map(({ name, level }) => (
              <li class="flex items-center justify-between gap-2">
                <span class="text-sm font-medium text-base-content">{name}</span>
                <span class:list={["badge badge-sm", levelBadge[level]]}>
                  {levelLabel[lang][level] ?? level}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>

