---
import { getFeaturedProjects } from "../../lib/cms/projects";
import ProjectCard from "../projects/ProjectCard.astro";
import Section from "../layout/Section.astro";

interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;

const featuredProjects = await getFeaturedProjects();
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const allProjectsHref = lang === "pl" ? `${base}pl/projects` : `${base}projects`;
---
<Section id="projects">
  <div class="mb-10 flex items-end justify-between">
    <div>
      <h2 class="text-3xl font-bold tracking-tight">
        {lang === "pl" ? "Wyróżnione projekty" : "Featured Projects"}
      </h2>
      <p class="mt-2 text-base-content/60">
        {lang === "pl"
          ? "Wybrane realne systemy, które zbudowałem lub znacząco współtworzyłem."
          : "A selection of real systems I built or contributed to significantly."}
      </p>
    </div>
    <a href={allProjectsHref} class="btn btn-outline btn-sm hidden md:inline-flex">
      {lang === "pl" ? "Wszystkie projekty ->" : "All projects ->"}
    </a>
  </div>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {featuredProjects.map((project) => <ProjectCard project={project} />)}
  </div>
  <div class="mt-8 md:hidden">
    <a href={allProjectsHref} class="btn btn-outline w-full">
      {lang === "pl" ? "Wszystkie projekty ->" : "All projects ->"}
    </a>
  </div>
</Section>

