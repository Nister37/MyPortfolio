---
import ThemeToggle from "../ui/ThemeToggle.astro";
import LanguageSwitcher from "../ui/LanguageSwitcher.astro";
import { base } from "../../lib/url";
interface Props {
  lang?: "en" | "pl";
  path?: string;
}
const { lang = "en", path = "/" } = Astro.props;
const navLinks = [
  { href: lang === "pl" ? `${base}pl` : base, label: lang === "pl" ? "Strona główna" : "Home" },
  { href: lang === "pl" ? `${base}pl/projects` : `${base}projects`, label: lang === "pl" ? "Projekty" : "Projects" },
  { href: lang === "pl" ? `${base}pl/blog` : `${base}blog`, label: "Blog" },
  { href: lang === "pl" ? `${base}pl/about` : `${base}about`, label: lang === "pl" ? "O mnie" : "About" },
];
const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.endsWith("/") && currentPath !== base
  ? currentPath.slice(0, -1)
  : currentPath;
function isActive(href: string) {
  return normalizedPath === href || normalizedPath === href.replace(/\/$/, "");
}

// CV picker dialog labels — kept here so both desktop trigger and mobile
// trigger share one source of truth.
const cvButtonLabel = lang === "pl" ? "Pobierz CV" : "Download CV";
const cvDialogTitle =
  lang === "pl"
    ? "W jakiej wersji językowej chcesz pobrać moje CV? 👀"
    : "Which language version of my CV would you like to download? 👀";
const cvEnglishLabel = lang === "pl" ? "Wersja angielska" : "English version";
const cvPolishLabel = lang === "pl" ? "Wersja polska" : "Polish version";
const cvCloseLabel = lang === "pl" ? "Zamknij" : "Close";
---
<header class="sticky top-0 z-50 border-b border-base-300 bg-base-100/90 backdrop-blur-sm">
  <div class="mx-auto grid max-w-[1120px] grid-cols-[1fr_auto_1fr] items-center px-4 py-3 md:gap-4">
    <!-- Left column kept empty on desktop to balance the centered nav. -->
    <div class="hidden md:block" aria-hidden="true"></div>

    <!-- Desktop navigation: centered between left spacer and right utilities. -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
              isActive(href)
                ? "bg-base-200 text-primary"
                : "text-base-content/70 hover:bg-base-200 hover:text-base-content",
            ]}
            aria-current={isActive(href) ? "page" : undefined}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop utilities: CV, theme, language — kept on the right. -->
    <div class="hidden items-center justify-end gap-2 md:flex">
      <button type="button" class="btn btn-primary btn-sm" data-cv-trigger>
        {cvButtonLabel}
      </button>
      <ThemeToggle />
      <LanguageSwitcher currentLang={lang} path={path} />
    </div>

    <!-- Mobile controls + hamburger span the full row on small screens. -->
    <div class="col-span-3 flex items-center justify-end gap-2 md:hidden">
      <!-- Larger class keeps the touch target ≥ 44 px on mobile. -->
      <ThemeToggle class="btn btn-ghost" />
      <LanguageSwitcher currentLang={lang} path={path} />
      <div class="drawer drawer-end">
        <input id="mobile-nav" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content">
          <label
            for="mobile-nav"
            class="btn btn-ghost"
            aria-label="Open navigation menu"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"
              ></path>
            </svg>
          </label>
        </div>
        <div class="drawer-side">
          <label
            for="mobile-nav"
            aria-label="Close navigation menu"
            class="drawer-overlay"
          ></label>
          <nav
            class="flex min-h-full w-64 flex-col gap-1 bg-base-200 p-6 pt-16"
            aria-label="Mobile navigation"
          >
            {
              navLinks.map(({ href, label }) => (
                <a
                  href={href}
                  class:list={[
                    "rounded-md px-4 py-3 text-base font-medium transition-colors",
                    isActive(href)
                      ? "bg-base-300 text-primary"
                      : "text-base-content/70 hover:bg-base-300 hover:text-base-content",
                  ]}
                  aria-current={isActive(href) ? "page" : undefined}
                >
                  {label}
                </a>
              ))
            }
            <button type="button" class="btn btn-primary mt-4" data-cv-trigger>
              {cvButtonLabel}
            </button>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- CV language picker: custom overlay (NOT native <dialog>) because <dialog>
     uses the browser top layer which always renders above the custom cursor
     regardless of z-index. Plain fixed overlay below the cursor's z-index. -->
<div id="cv-dialog" class="cv-dialog" role="dialog" aria-modal="true" aria-labelledby="cv-dialog-title" aria-hidden="true" hidden>
  <div class="cv-dialog__backdrop" data-cv-close aria-hidden="true"></div>
  <div class="cv-dialog__panel" role="document">
    <button
      type="button"
      class="cv-dialog__close"
      data-cv-close
      aria-label={cvCloseLabel}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <h2 id="cv-dialog-title" class="cv-dialog__title">{cvDialogTitle}</h2>

    <div class="cv-dialog__actions">
      <a
        href={`${base}cv-en.pdf`}
        class="btn btn-primary"
        target="_blank"
        rel="noopener noreferrer"
        download
      >
        🇬🇧 {cvEnglishLabel}
      </a>
      <a
        href={`${base}cv-pl.pdf`}
        class="btn btn-outline"
        target="_blank"
        rel="noopener noreferrer"
        download
      >
        🇵🇱 {cvPolishLabel}
      </a>
    </div>
  </div>
</div>

<script>
  // Custom overlay control: open/close + ESC + backdrop click. Hidden via the
  // `hidden` attribute when inactive so it never intercepts events or takes
  // tab focus. Body scroll is locked while the dialog is open.
  const overlay = document.getElementById("cv-dialog");
  if (overlay) {
    const open = () => {
      overlay.hidden = false;
      overlay.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      overlay.hidden = true;
      overlay.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };
    document.querySelectorAll<HTMLButtonElement>("[data-cv-trigger]").forEach((btn) => {
      btn.addEventListener("click", open);
    });
    overlay.querySelectorAll<HTMLElement>("[data-cv-close]").forEach((el) => {
      el.addEventListener("click", close);
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !overlay.hidden) close();
    });
  }
</script>

<style>
  /* z-index sits below the custom cursor (9999) so the triangle remains
     visible inside the modal. */
  .cv-dialog {
    position: fixed;
    inset: 0;
    z-index: 9000;
  }

  .cv-dialog__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.55);
    backdrop-filter: blur(2px);
    animation: cv-fade-in 0.18s ease-out;
  }

  /* Absolute centering via top/left 50% + translate is bulletproof against
     flexbox/grid quirks and parent containing-block surprises. */
  .cv-dialog__panel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(480px, calc(100vw - 2rem));
    border-radius: 0.85rem;
    background: var(--color-base-100, #fff);
    color: var(--color-base-content, inherit);
    border: 1px solid var(--color-base-300, #e5e7eb);
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.35);
    padding: 1.75rem 1.5rem 1.5rem;
    animation: cv-panel-in 0.18s ease-out;
  }

  @keyframes cv-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  /* Centering transform is preserved in both keyframes so the animation does
     not knock the panel off-center mid-tween. */
  @keyframes cv-panel-in {
    from { opacity: 0; transform: translate(-50%, calc(-50% - 6px)) scale(0.98); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }

  .cv-dialog__close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: transparent;
    color: var(--color-base-content, currentColor);
    opacity: 0.6;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s ease, background-color 0.15s ease;
  }
  .cv-dialog__close:hover {
    opacity: 1;
    background: color-mix(in srgb, var(--color-base-content, #000) 8%, transparent);
  }

  .cv-dialog__title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.45;
    margin: 0 1.5rem 1.25rem 0;
  }

  /* Side-by-side buttons; wrap to two rows only if there isn't room. */
  .cv-dialog__actions {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .cv-dialog__actions > .btn {
    flex: 1 1 0;
    min-width: 140px;
  }
</style>





