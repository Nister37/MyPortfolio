---
interface Props {
  lang?: "en" | "pl";
}
const { lang = "en" } = Astro.props;
const year = new Date().getFullYear();

const copyright =
  lang === "pl"
    ? `© ${year} Paweł Ryfiak. Zbudowane przy użyciu Astro, Svelte, Tailwind CSS i Strapi.`
    : `© ${year} Paweł Ryfiak. Built with Astro, Svelte, Tailwind CSS, and Strapi.`;
---

<footer class="border-t border-base-300 bg-base-200">
  <div class="mx-auto max-w-[1120px] px-4 py-6">
    <p class="text-center text-xs text-base-content/50">
      {copyright}
    </p>
  </div>
</footer>
